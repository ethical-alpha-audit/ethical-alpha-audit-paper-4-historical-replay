{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Historical Replay Case Input",
  "type": "object",
  "required": [
    "case_id",
    "display_name",
    "sector",
    "features"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "citation": {
      "type": "string"
    },
    "evidence_excerpt": {
      "type": "string"
    },
    "case_summary": {
      "type": "string"
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "value_primary",
          "confidence_level",
          "provenance_class"
        ],
        "properties": {
          "value_primary": {
            "type": "number"
          },
          "value_low": {
            "type": "number"
          },
          "value_high": {
            "type": "number"
          },
          "confidence_level": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "provenance_class": {
            "type": "string",
            "enum": [
              "direct_evidence",
              "rule_derived",
              "imputed_from_context",
              "uncertain_estimate"
            ]
          },
          "encoding_rule_id": {
            "type": "string"
          },
          "excerpt_ids": {
            "type": "array"
          },
          "source_refs": {
            "type": "array"
          }
        }
      }
    }
  }
}